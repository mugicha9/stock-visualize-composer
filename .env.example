APP_DATA_DIR=./data
APP_DATABASE_PATH=./data/app.db
APP_SETTINGS_PATH=./config/app_settings.json
DEFAULT_LLM_PROVIDER=llama_cpp
LLAMA_CPP_BASE_URL=http://127.0.0.1:10000
LLAMA_CPP_MODEL_NAME=qwen3.6-35b-a3b
LLAMA_CPP_TIMEOUT_SECONDS=240
LLAMA_CPP_TEMPERATURE=0.6
LLAMA_CPP_TOP_P=0.95
LLAMA_CPP_TOP_K=20
LLAMA_CPP_MIN_P=0.0
LLAMA_CPP_PRESENCE_PENALTY=0.0
LLAMA_CPP_REPEAT_PENALTY=1.0
LLAMA_CPP_CONTAINER_NAME=llama-qwen36-cuda
LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_CPP_DOCKER_RESTART=unless-stopped
LLAMA_CPP_DOCKER_GPUS=all
LLAMA_CPP_HOST_MODELS_DIR=data/llama-models
LLAMA_CPP_CONTAINER_MODELS_DIR=/models
LLAMA_CPP_MODEL_FILE=Qwen3.6-35B-A3B-UD-IQ4_NL_XL.gguf
LLAMA_CPP_ALIAS=qwen3.6-35b-a3b
LLAMA_CPP_HOST=0.0.0.0
LLAMA_CPP_PORT=10000
LLAMA_CPP_CONTAINER_PORT=8080
LLAMA_CPP_CONTEXT_LENGTH=32768
LLAMA_CPP_N_PARALLEL=1
LLAMA_CPP_NCMOE=24
LLAMA_CPP_GPU_LAYERS=auto
LLAMA_CPP_NO_MMAP=false
LLAMA_CPP_CHAT_TEMPLATE_KWARGS='{"preserve_thinking":false}'
LLAMA_CPP_REASONING=off
LLAMA_CPP_REASONING_BUDGET=0
LLAMA_CPP_DOCKER_ENV_JSON='{"NVIDIA_VISIBLE_DEVICES":"all","NVIDIA_DRIVER_CAPABILITIES":"compute,utility,graphics"}'
LLAMA_CPP_EXTRA_ARGS=
NEWS_SUMMARY_PROVIDER=llama_cpp
NEWS_SUMMARY_MAX_ITEMS=12
NEWS_SUMMARY_TIMEOUT_SECONDS=45
NEWS_SUMMARY_ON_UPDATE=0
COMPANY_NEWS_FETCH_LIMIT=20
COMPANY_NEWS_KEYWORD_PROFILE_ENABLED=1
COMPANY_NEWS_KEYWORD_PROFILE_REFRESH_DAYS=30
COMPANY_NEWS_RELEVANCE_MIN_SCORE=0.35
COMPANY_NEWS_KEYWORD_FETCH_MULTIPLIER=4
GLOBAL_NEWS_FETCH_LIMIT_PER_SOURCE=40
LLM_NEWS_SELECTION_MAX_COMPANY=4
LLM_NEWS_SELECTION_MAX_GLOBAL=5
DISCLOSURE_PDF_EXTRACT_ON_UPDATE=1
DISCLOSURE_PDF_EXTRACT_LIMIT=3
DISCLOSURE_PDF_MAX_PAGES=8
DISCLOSURE_PDF_OCR_ENABLED=0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
